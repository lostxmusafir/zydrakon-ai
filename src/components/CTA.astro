---
import { Icon } from 'astro-icon/components';
---

<section class="py-24 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-secondary/5 to-accent/10" />
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;" />

  <div class="container relative z-10 text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-4">
      Let's Build the Future Together
    </h2>
    <p class="text-text-secondary max-w-xl mx-auto mb-10 leading-relaxed">
      Have a project in mind? Want to collaborate? Reach out and let's create something extraordinary.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/contact"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl bg-primary hover:bg-primary-dark text-white font-semibold text-sm transition-all shadow-lg shadow-primary/25 hover:shadow-primary/40 hover:-translate-y-0.5"
      >
        Get in Touch
        <Icon name="lucide:send" size="16" />
      </a>
      <a
        href="/products"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl border border-white/10 hover:border-white/20 text-text-primary font-semibold text-sm transition-all hover:bg-white/5"
      >
        View Products
        <Icon name="lucide:arrow-right" size="16" />
      </a>
    </div>
  </div>
</section>
