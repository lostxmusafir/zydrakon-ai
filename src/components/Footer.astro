---
import { site } from '../data/site';
import { Icon } from 'astro-icon/components';
---

<footer class="border-t border-white/5 bg-surface/50">
  <div class="container py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2 mb-4">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10 text-primary font-mono font-bold text-sm">Z</span>
          <span class="font-semibold text-lg tracking-tight text-text-primary">{site.name}</span>
        </a>
        <p class="text-text-muted text-sm max-w-sm leading-relaxed">
          {site.description}
        </p>
        <p class="mt-3 text-sm text-text-muted">
          Founded by{' '}
          <a href="/about" class="text-primary hover:text-primary-light transition-colors">
            {site.founder.name}
          </a>
        </p>
        <div class="flex items-center gap-3 mt-5">
          <a
            href={site.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center w-10 h-10 rounded-lg bg-white/5 text-text-muted hover:bg-primary/10 hover:text-primary transition-colors"
            aria-label="LinkedIn"
          >
            <Icon name="lucide:linkedin" size="18" />
          </a>
          <a
            href={site.social.github}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center w-10 h-10 rounded-lg bg-white/5 text-text-muted hover:bg-primary/10 hover:text-primary transition-colors"
            aria-label="GitHub"
          >
            <Icon name="lucide:github" size="18" />
          </a>
        </div>
      </div>

      <div>
        <h4 class="font-semibold text-sm text-text-primary mb-4">Pages</h4>
        <nav class="flex flex-col gap-3">
          {site.nav.map((item) => (
            <a
              href={item.href}
              class="text-sm text-text-muted hover:text-text-primary transition-colors"
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>

      <div>
        <h4 class="font-semibold text-sm text-text-primary mb-4">Connect</h4>
        <nav class="flex flex-col gap-3">
          <a
            href={site.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-text-muted hover:text-text-primary transition-colors"
          >
            LinkedIn
          </a>
          <a
            href={site.social.github}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-text-muted hover:text-text-primary transition-colors"
          >
            GitHub
          </a>
          <a
            href="/contact"
            class="text-sm text-text-muted hover:text-text-primary transition-colors"
          >
            Contact
          </a>
        </nav>
      </div>
    </div>
  </div>

  <div class="border-t border-white/5 py-6">
    <div class="container flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-sm text-text-muted">
        &copy; {new Date().getFullYear()} {site.name}. All rights reserved.
      </p>
      <p class="text-sm text-text-muted">
        Founder &amp; CEO —{' '}
        <a href="/about" class="text-primary hover:text-primary-light transition-colors">
          {site.founder.name}
        </a>
      </p>
    </div>
  </div>
</footer>
