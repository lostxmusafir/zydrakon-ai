---
import { site } from '../data/site';
import { Icon } from 'astro-icon/components';
---

<section class="py-24">
  <div class="container">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="relative">
        <div class="aspect-[9/16] max-w-sm mx-auto rounded-2xl bg-gradient-to-br from-primary/20 via-secondary/10 to-accent/20 p-1 overflow-hidden group">
          <div class="relative h-full w-full rounded-2xl overflow-hidden bg-surface">
            <img src="/images/founder.jpg" alt={site.founder.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-base via-base/30 to-transparent flex flex-col justify-end p-8">
              <h3 class="text-2xl font-bold text-text-primary">{site.founder.name}</h3>
              <p class="text-primary-light text-sm font-medium mt-1">{site.founder.title}</p>
            </div>
          </div>
        </div>
        <div class="absolute -bottom-4 -right-4 w-32 h-32 bg-primary/10 rounded-full blur-2xl pointer-events-none" />
      </div>

      <div class="animate-fade-in-up">
        <span class="text-xs font-semibold uppercase tracking-widest text-primary">Founder &amp; CEO</span>
        <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4 text-text-primary">
          Meet <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">{site.founder.name}</span>
        </h2>
        <p class="text-text-secondary leading-relaxed mb-6">{site.founder.bio}</p>

        <div class="flex flex-wrap gap-3 mb-8">
          {site.founder.roles.map((role) => (
            <span class="px-4 py-2 rounded-lg bg-white/5 border border-white/5 text-text-muted text-sm font-medium">
              {role}
            </span>
          ))}
        </div>

        <div class="flex items-center gap-4">
          <a
            href="/founder"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-primary hover:bg-primary-dark text-white font-semibold text-sm transition-all shadow-lg shadow-primary/25 hover:shadow-primary/40"
          >
            Full Story
            <Icon name="lucide:arrow-right" size="16" />
          </a>
          <a
            href={site.founder.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center w-11 h-11 rounded-xl bg-white/5 text-text-muted hover:bg-primary/10 hover:text-primary transition-colors"
            aria-label="LinkedIn"
          >
            <Icon name="lucide:linkedin" size="20" />
          </a>
          <a
            href={site.founder.github}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center w-11 h-11 rounded-xl bg-white/5 text-text-muted hover:bg-primary/10 hover:text-primary transition-colors"
            aria-label="GitHub"
          >
            <Icon name="lucide:github" size="20" />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
