---
import { site } from '../data/site';
import { Icon } from 'astro-icon/components';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-white/5 bg-base/80 backdrop-blur-xl">
  <div class="container flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10 text-primary font-mono font-bold text-sm group-hover:bg-primary/20 transition-colors">Z</span>
      <span class="font-semibold text-lg tracking-tight text-text-primary">{site.name}</span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {site.nav.map((item) => {
        const isActive = (item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href));
        return (
          <a
            href={item.href}
            class="px-4 py-2 rounded-lg text-sm font-medium transition-colors"
            class:list={[
              isActive
                ? 'bg-primary/10 text-primary'
                : 'text-text-muted hover:text-text-primary hover:bg-white/5',
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <button
      id="mobile-menu-toggle"
      class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg text-text-muted hover:text-text-primary hover:bg-white/5 transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <Icon name="lucide:menu" size="20" />
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-white/5 bg-base/95 backdrop-blur-xl">
    <div class="container py-4 space-y-1">
      {site.nav.map((item) => {
        const isActive = (item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href));
        return (
          <a
            href={item.href}
            class="block px-4 py-3 rounded-lg text-sm font-medium transition-colors"
            class:list={[
              isActive
                ? 'bg-primary/10 text-primary'
                : 'text-text-muted hover:text-text-primary hover:bg-white/5',
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </div>
  </div>
</header>
