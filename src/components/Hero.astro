---
import { site } from '../data/site';
import { Icon } from 'astro-icon/components';
---

<section class="relative min-h-[90vh] flex items-center overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-primary/5 via-transparent to-base pointer-events-none" />
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;" />

  <div class="container relative z-10 pt-20 pb-24 md:pt-28 md:pb-32">
    <div class="max-w-4xl">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 border border-primary/20 text-primary text-sm font-medium mb-8 animate-fade-in-up">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
        </span>
        Founded by {site.founder.name}
      </div>

      <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold tracking-tight leading-[1.1] mb-6 animate-fade-in-up">
        <span class="text-text-primary">Engineer the</span>
        <br />
        <span class="bg-gradient-to-r from-primary via-accent to-secondary bg-clip-text text-transparent">
          Future of Intelligence
        </span>
      </h1>

      <p class="text-lg md:text-xl text-text-secondary max-w-2xl leading-relaxed mb-10 animate-fade-in-up" style="animation-delay: 0.2s">
        {site.description}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up" style="animation-delay: 0.3s">
        <a
          href="/products"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl bg-primary hover:bg-primary-dark text-white font-semibold text-sm transition-all shadow-lg shadow-primary/25 hover:shadow-primary/40 hover:-translate-y-0.5"
        >
          Explore Products
          <Icon name="lucide:arrow-right" size="16" />
        </a>
        <a
          href="/founder"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl border border-white/10 hover:border-white/20 text-text-primary font-semibold text-sm transition-all hover:bg-white/5"
        >
          Meet the Founder
        </a>
      </div>
    </div>

    <div class="absolute right-0 top-1/2 -translate-y-1/2 hidden xl:block pointer-events-none">
      <div class="relative w-[400px] h-[400px]">
        <div class="absolute inset-0 bg-gradient-to-br from-primary/20 via-secondary/10 to-accent/20 rounded-full blur-3xl animate-glow" />
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="grid grid-cols-6 gap-3 opacity-[0.07]">
            {Array.from({ length: 36 }).map(() => (
              <div class="w-3 h-3 rounded-sm bg-white" />
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
