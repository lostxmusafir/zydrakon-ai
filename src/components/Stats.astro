---
const stats = [
  { value: '2024', label: 'Founded' },
  { value: '3', label: 'AI Products' },
  { value: '12+', label: 'Open Source Repos' },
  { value: '100%', label: 'Founder-Led' },
];
---

<section class="py-16 border-y border-white/5 bg-surface/30">
  <div class="container">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {stats.map((stat, i) => (
        <div class="text-center animate-fade-in-up" style={`animation-delay: ${i * 0.1}s`}>
          <div class="text-3xl md:text-4xl font-bold bg-gradient-to-b from-text-primary to-text-muted bg-clip-text text-transparent">
            {stat.value}
          </div>
          <div class="mt-2 text-sm text-text-muted font-medium">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
