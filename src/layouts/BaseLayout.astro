---
import '../styles/global.css';
import SchemaOrg from '../components/SchemaOrg.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site, pageMeta } from '../data/site';

interface Props {
  page: string;
  breadcrumbs?: { name: string; path: string }[];
  customTitle?: string;
  customDescription?: string;
}

const { page, breadcrumbs, customTitle, customDescription } = Astro.props;
const meta = pageMeta[page];
const title = customTitle || meta?.title || site.name;
const description = customDescription || meta?.description || site.description;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={`${site.url}${page}`} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${site.url}${page}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:image" content={`${site.url}/og-image.png`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <SchemaOrg page={page} breadcrumbs={breadcrumbs} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <script is:inline>
      document.addEventListener('astro:page-load', () => {
        const toggle = document.getElementById('mobile-menu-toggle');
        const menu = document.getElementById('mobile-menu');
        if (toggle && menu) {
          toggle.addEventListener('click', () => {
            const isOpen = menu.classList.toggle('hidden');
            toggle.setAttribute('aria-expanded', String(!isOpen));
          });
        }
      });
    </script>
  </body>
</html>
