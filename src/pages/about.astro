---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { site } from '../data/site';
import { Icon } from 'astro-icon/components';
---

<BaseLayout page="/about" breadcrumbs={[{ name: 'Home', path: '/' }, { name: 'About', path: '/about' }]}>
  <section class="relative overflow-hidden pt-20 pb-24">
    <div class="absolute inset-0 bg-gradient-to-b from-secondary/10 via-transparent to-base pointer-events-none" />
    
    <div class="container relative z-10">
      <div class="grid md:grid-cols-5 gap-12 items-start">
        <div class="md:col-span-2 md:sticky md:top-28">
          <div class="aspect-[9/16] max-w-sm mx-auto rounded-2xl bg-gradient-to-br from-primary/20 via-secondary/10 to-accent/20 p-1 overflow-hidden group">
            <div class="relative h-full w-full rounded-2xl overflow-hidden bg-surface">
              <img src="/images/founder.jpg" alt={site.founder.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
              <div class="absolute inset-0 bg-gradient-to-t from-base via-base/30 to-transparent flex flex-col justify-end p-8">
                <h1 class="text-3xl font-bold text-text-primary">{site.founder.name}</h1>
                <p class="text-primary-light text-sm font-medium mt-1">{site.founder.title}</p>
                <div class="flex gap-3 mt-4">
                  <a
                    href={site.founder.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center justify-center w-10 h-10 rounded-xl bg-white/10 text-white hover:bg-primary hover:text-white transition-colors backdrop-blur-md"
                    aria-label="LinkedIn"
                  >
                    <Icon name="lucide:linkedin" size="18" />
                  </a>
                  <a
                    href={site.founder.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center justify-center w-10 h-10 rounded-xl bg-white/10 text-white hover:bg-primary hover:text-white transition-colors backdrop-blur-md"
                    aria-label="GitHub"
                  >
                    <Icon name="lucide:github" size="18" />
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="md:col-span-3">
          <span class="text-xs font-semibold uppercase tracking-widest text-primary">About</span>
          <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-6 text-text-primary">
            The Story Behind{' '}
            <span class="bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent">
              Zydrakon AI
            </span>
          </h2>

          <div class="space-y-5 text-text-secondary leading-relaxed">
            <p>{site.founder.bio}</p>
            <p>
              With a deep understanding of backend systems, artificial intelligence, and agentic frameworks,
              Raj founded Zydrakon AI with a mission to build intelligent systems that don't just process data
              but truly understand and act upon it. The company focuses on creating AI products that are
              practical, scalable, and engineered for the real world.
            </p>
            <p>
              Raj's expertise spans the full stack of AI development — from designing distributed backend
              architectures to building autonomous agent systems that can reason, plan, and execute complex
              tasks. This breadth of experience drives Zydrakon AI's product vision and engineering excellence.
            </p>
          </div>

          <div class="mt-10">
            <h3 class="text-xl font-bold text-text-primary mb-6">Areas of Expertise</h3>
            <div class="grid sm:grid-cols-2 gap-4">
              {[
                { icon: 'braces', title: 'AI Engineering', desc: 'LLMs, agentic systems, RAG pipelines, model fine-tuning' },
                { icon: 'server', title: 'Backend Development', desc: 'Distributed systems, APIs, cloud infrastructure, databases' },
                { icon: 'bot', title: 'Agentic AI', desc: 'Autonomous agents, tool-use frameworks, multi-agent coordination' },
                { icon: 'code-2', title: 'Open Source', desc: 'Building tools that empower developers worldwide' },
              ].map((skill) => (
                <div class="p-5 rounded-xl bg-surface/50 border border-white/5">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary mb-3">
                    <Icon name={`lucide:${skill.icon}`} size="20" />
                  </div>
                  <h4 class="font-semibold text-text-primary text-sm mb-1">{skill.title}</h4>
                  <p class="text-xs text-text-muted">{skill.desc}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="mt-10 grid grid-cols-3 gap-6 p-6 rounded-xl bg-surface/30 border border-white/5">
            {[
              { value: '4+', label: 'Years Building' },
              { value: '20+', label: 'Projects' },
              { value: '∞', label: 'Curiosity' },
            ].map((stat) => (
              <div class="text-center">
                <div class="text-2xl font-bold text-primary">{stat.value}</div>
                <div class="text-xs text-text-muted mt-1">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
