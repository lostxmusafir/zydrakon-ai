---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { site } from '../data/site';
import { Icon } from 'astro-icon/components';
---

<BaseLayout page="/founder" breadcrumbs={[{ name: 'Home', path: '/' }, { name: 'Founder', path: '/founder' }]}>
  <section class="relative overflow-hidden pt-20 pb-24">
    <div class="absolute inset-0 bg-gradient-to-b from-secondary/10 via-transparent to-base pointer-events-none" />
    
    <div class="container relative z-10">
      <div class="grid md:grid-cols-5 gap-12 items-start">
        <div class="md:col-span-2 md:sticky md:top-28">
          <div class="aspect-[9/16] max-w-sm mx-auto rounded-2xl bg-gradient-to-br from-primary/20 via-secondary/10 to-accent/20 p-1 overflow-hidden group">
            <div class="relative h-full w-full rounded-2xl overflow-hidden bg-surface">
              <img src="/images/founder.jpg" alt={site.founder.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
              <div class="absolute inset-0 bg-gradient-to-t from-base via-base/30 to-transparent flex flex-col justify-end p-8">
                <h1 class="text-3xl font-bold text-text-primary">{site.founder.name}</h1>
                <p class="text-primary-light text-sm font-medium mt-1">{site.founder.title}</p>
                <div class="flex gap-3 mt-4">
                  <a
                    href={site.founder.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center justify-center w-10 h-10 rounded-xl bg-white/10 text-white hover:bg-primary hover:text-white transition-colors backdrop-blur-md"
                    aria-label="LinkedIn"
                  >
                    <Icon name="lucide:linkedin" size="18" />
                  </a>
                  <a
                    href={site.founder.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center justify-center w-10 h-10 rounded-xl bg-white/10 text-white hover:bg-primary hover:text-white transition-colors backdrop-blur-md"
                    aria-label="GitHub"
                  >
                    <Icon name="lucide:github" size="18" />
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="md:col-span-3">
          <span class="text-xs font-semibold uppercase tracking-widest text-primary">Founder & CEO</span>
          <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-6 text-text-primary">
            Meet{' '}
            <span class="bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent">
              {site.founder.name}
            </span>
          </h2>

          <div class="space-y-5 text-text-secondary leading-relaxed">
            <p>
              Hi, I'm Raj Patil. I am an AI Engineer, Backend Architect, and the Founder & CEO of Zydrakon AI.
              My work focuses on building the infrastructure and orchestration layers required for autonomous agentic systems that run at scale.
            </p>
            <p>
              Over the past 4+ years, I have engineered high-performance distributed systems, designed robust API layers, and created frameworks that enable LLMs to dynamically orchestrate workflows, interact with databases, and complete complex multi-turn tasks.
            </p>
            <p>
              I believe the next wave of computing will be defined not just by chatbots, but by **agentic systems**—AI that can plan, reason, correct its own errors, and execute tasks autonomously. At Zydrakon AI, we are building developer tools, safety guardrails, and enterprise platforms to make this future practical and scalable.
            </p>
          </div>

          <div class="mt-10">
            <h3 class="text-xl font-bold text-text-primary mb-6">Expertise & Technologies</h3>
            <div class="grid sm:grid-cols-2 gap-4">
              {[
                { icon: 'braces', title: 'Agentic AI Architecture', desc: 'Tool-use systems, memory retrieval pipelines, multi-agent frameworks.' },
                { icon: 'server', title: 'Backend Systems', desc: 'Distributed servers, real-time sync, high-throughput APIs, databases.' },
                { icon: 'shield-check', title: 'AI Safety & Guardrails', desc: 'Anomaly detection, input/output validation, compliance layers.' },
                { icon: 'git-branch', title: 'Open Source', desc: 'Abstractions that help developers build agentic systems efficiently.' },
              ].map((skill) => (
                <div class="p-5 rounded-xl bg-surface/50 border border-white/5">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary mb-3">
                    <Icon name={`lucide:${skill.icon}`} size="20" />
                  </div>
                  <h4 class="font-semibold text-text-primary text-sm mb-1">{skill.title}</h4>
                  <p class="text-xs text-text-muted">{skill.desc}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="mt-10 p-6 rounded-xl bg-surface/30 border border-white/5">
            <h3 class="text-lg font-bold text-text-primary mb-4">Founder's Message</h3>
            <blockquote class="italic text-text-secondary border-l-2 border-primary pl-4 py-1 leading-relaxed">
              "We are at a historic transition point in software engineering. We are moving from code that we write line-by-line, to instructions that AI agents can reason about and execute autonomously. Our goal at Zydrakon AI is to build the foundational systems that make this transition safe, reliable, and accessible to every development team."
            </blockquote>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
