---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import ProductCard from '../components/ProductCard.astro';
import FounderPreview from '../components/FounderPreview.astro';
import CTA from '../components/CTA.astro';
import { products } from '../data/products';
---

<BaseLayout page="/">
  <Hero />
  <Stats />
  <section class="py-24">
    <div class="container">
      <div class="text-center mb-16">
        <span class="text-xs font-semibold uppercase tracking-widest text-primary">Products</span>
        <h2 class="text-3xl md:text-4xl font-bold mt-3 text-text-primary">
          AI Products Engineered for Scale
        </h2>
        <p class="text-text-secondary mt-3 max-w-xl mx-auto">
          From agentic frameworks to enterprise platforms — built by engineers who push the boundaries of AI.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {products.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
    </div>
  </section>
  <FounderPreview />
  <CTA />
</BaseLayout>
