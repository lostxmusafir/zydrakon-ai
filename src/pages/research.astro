---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout page="/research" breadcrumbs={[{ name: 'Home', path: '/' }, { name: 'Research', path: '/research' }]}>
  <section class="relative overflow-hidden pt-20 pb-24">
    <div class="absolute inset-0 bg-gradient-to-b from-primary/5 via-transparent to-base pointer-events-none" />

    <div class="container relative z-10">
      <div class="text-center max-w-3xl mx-auto mb-16 animate-fade-in-up">
        <span class="text-xs font-semibold uppercase tracking-widest text-primary">Research Lab</span>
        <h1 class="text-4xl md:text-5xl font-bold mt-3 mb-4 text-text-primary">
          Pioneering Agentic Intelligence
        </h1>
        <p class="text-text-secondary leading-relaxed">
          At Zydrakon AI, we combine academic rigor with practical systems engineering to solve the hardest problems in agentic workflows, safety guardrails, and autonomous decision-making.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 mb-16">
        {[
          {
            icon: 'bot',
            title: 'Agentic Reasoning',
            desc: 'Designing protocols and prompting engines that allow LLMs to break down complex goals, plan multi-step actions, and recover from failures autonomously.',
          },
          {
            icon: 'database',
            title: 'Long-term Memory',
            desc: 'Researching vector database storage architectures, contextual chunking, and memory retrieval pipelines that allow agents to retain knowledge across sessions.',
          },
          {
            icon: 'shield',
            title: 'Safety Guardrails',
            desc: 'Developing output verification systems and alignment protocols that validate AI outputs in real-time before they trigger external database modifications or API actions.',
          },
        ].map((area) => (
          <div class="p-8 rounded-2xl border border-white/5 bg-surface/50 hover:bg-surface/80 hover:border-white/10 transition-all">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary mb-6">
              <Icon name={`lucide:${area.icon}`} size="24" />
            </div>
            <h3 class="text-xl font-bold text-text-primary mb-3">{area.title}</h3>
            <p class="text-sm text-text-muted leading-relaxed">{area.desc}</p>
          </div>
        ))}
      </div>

      <div class="border-t border-white/5 pt-16">
        <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-8">Technical Reports &amp; Publications</h2>
        
        <div class="space-y-6">
          {[
            {
              title: 'Forge Protocol: Multi-agent Coordination and Tool-use Abstractions',
              authors: 'Raj Patil, Zydrakon AI Lab',
              date: 'June 2026',
              desc: 'This paper introduces the Forge SDK abstractions for multi-agent coordination, detailing standard message formats, tool schemas, and agent context compression algorithms.',
              tags: ['SDK', 'Agentic Systems', 'Multi-Agent'],
            },
            {
              title: 'Sentinel Safety Model: Output Guardrails and Alignment Checking in Agentic Pipelines',
              authors: 'Raj Patil, Zydrakon AI Lab',
              date: 'April 2026',
              desc: 'An exploration of real-time validation layers that check agent tool calls and generated JSON outputs against compliance policies using low-latency evaluation pipelines.',
              tags: ['AI Safety', 'Guardrails', 'Compliance'],
            },
          ].map((pub) => (
            <div class="p-6 rounded-xl border border-white/5 bg-surface/30 hover:border-white/10 transition-all flex flex-col sm:flex-row justify-between items-start gap-4">
              <div>
                <span class="text-xs font-semibold text-primary">{pub.date}</span>
                <h3 class="text-lg font-bold text-text-primary mt-1 mb-2">{pub.title}</h3>
                <p class="text-xs text-text-muted mb-3">Authors: {pub.authors}</p>
                <p class="text-sm text-text-secondary leading-relaxed max-w-3xl mb-4">{pub.desc}</p>
                <div class="flex gap-2">
                  {pub.tags.map((tag) => (
                    <span class="px-2.5 py-1 rounded bg-white/5 border border-white/5 text-text-muted text-xs">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
              <a
                href="#"
                class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-white/5 hover:bg-primary/10 hover:text-primary text-text-muted text-xs font-semibold transition-colors shrink-0"
              >
                Read Paper
                <Icon name="lucide:external-link" size="14" />
              </a>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
